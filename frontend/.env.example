# Smart Attendance Pro — Frontend Environment TEMPLATE
# Copy file ini ke .env dan isi sesuai konfigurasi klien
# Atau jalankan: node setup-client.js (dari root project)
# ═══════════════════════════════════════════════════

# Port frontend (default: 5173)
VITE_PORT=5173

# Backend API URL (sesuaikan IP dan PORT backend klien)
VITE_API_URL=http://localhost:5000
