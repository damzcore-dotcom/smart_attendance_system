# ═══════════════════════════════════════════════════
# Smart Attendance Pro — Backend Environment TEMPLATE
# Copy file ini ke .env dan isi sesuai konfigurasi klien
# Atau jalankan: node setup-client.js
# ═══════════════════════════════════════════════════

# Database (WAJIB — sesuaikan password PostgreSQL klien)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/smart_attendance"

# Server
PORT=5000
CORS_ORIGINS="http://localhost:5173"

# JWT Authentication (WAJIB — harus unik per klien!)
JWT_SECRET="CHANGE_THIS_TO_RANDOM_SECRET"
JWT_REFRESH_SECRET="CHANGE_THIS_TO_ANOTHER_SECRET"

# License System (WAJIB — di-generate oleh vendor)
INITIAL_LICENSE_KEY="CHANGE_THIS_TO_YOUR_LICENSE_KEY"

# Google Gemini API (Untuk Fitur AI Chatbot Agent)
# Dapatkan API Key gratis di: https://aistudio.google.com/
GEMINI_API_KEY="CHANGE_ME_TO_YOUR_GEMINI_API_KEY"

# Mode Chatbot: "local" (Engine NLP offline) atau "gemini" (Google Gemini API)
CHATBOT_MODE="local"
