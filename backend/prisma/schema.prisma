generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  DIREKTUR
  MANAGER
  EMPLOYEE
}

enum EmpStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

enum FaceStatus {
  ENROLLED
  PENDING
}

enum AttStatus {
  PRESENT
  LATE
  ABSENT
  MANGKIR
  SAKIT
  IZIN
  CUTI
  HOLIDAY
}

enum ReqStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayrollStatus {
  DRAFT
  AWAITING_APPROVAL
  APPROVED
  COMPLETED
  REJECTED
  CANCELLED
}

// ─── Models ─────────────────────────────────────────

model User {
  id           Int              @id @default(autoincrement())
  username     String           @unique
  password     String
  role         Role             @default(EMPLOYEE)
  employeeId   Int?             @unique
  employee     Employee?        @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  managerAccess ManagerAccess?
  permissions  MenuPermission[]
  refreshToken String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model ManagerAccess {
  id             Int        @id @default(autoincrement())
  userId         Int        @unique
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  managedDeptId  Int?       // NULL if manageAllDepts is true
  manageAllDepts Boolean    @default(false)
}

model MenuPermission {
  id        Int     @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  menuKey   String  // e.g., "dashboard", "attendance", "employees"
  canRead   Boolean @default(true)
  canCreate Boolean @default(false)
  canUpdate Boolean @default(false)
  canDelete Boolean @default(false)

  @@unique([userId, menuKey])
}

model Employee {
  id            Int        @id @default(autoincrement())
  employeeCode  String     @unique
  name          String
  email         String     @unique
  phone         String?
  position      String?
  division      String?
  locationId    String?
  idNumber      String?
  cardNo        String?
  verifyCode    String?
  grade             String?
  section           String?
  employmentStatus  String?
  contractDuration  String?
  joinDate          DateTime?
  contractEnd       DateTime?
  faceId            String?
  facePhoto         String?
  faceDescriptor    Json?
  bpjsTk            String?
  bpjsKesehatan     String?
  npwp              String?
  ptkpStatus        String?
  maritalStatus     String?
  kkNumber          String?
  birthDate         DateTime?
  birthPlace        String?
  address           String?
  education         String?
  major             String?
  religion          String?
  numberOfChildren  Int?
  fatherName        String?
  motherName        String?
  spouseName        String?
  emergencyContact  String?
  notes             String?
  salaryCategory    String?    @default("UMK/UMR")
  status        EmpStatus  @default(ACTIVE)
  faceStatus    FaceStatus @default(PENDING)
  leaveQuota     Int        @default(12)
  remainingLeave Int        @default(12)
  departmentId  Int
  department    Department @relation(fields: [departmentId], references: [id])
  shiftId       Int?
  shift         Shift?     @relation(fields: [shiftId], references: [id])
  attendance    Attendance[]
  corrections   CorrectionRequest[]
  leaveRequests LeaveRequest[]
  notifications Notification[]
  user          User?
  salary         EmployeeSalary?
  payrollDetails PayrollDetail[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  employees Employee[]
}

model Shift {
  id          Int        @id @default(autoincrement())
  name        String
  startTime   String     // "08:00"
  endTime     String     // "17:00"
  breakStart  String?    // "12:00"
  breakEnd    String?    // "13:00"
  gracePeriod Int        @default(15)
  employees   Employee[]
}

model Attendance {
  id          Int       @id @default(autoincrement())
  employeeId  Int
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime  @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  status      AttStatus @default(ABSENT)
  lateMinutes Int       @default(0)
  mode        String    @default("Credentials")
  notes       String?
  createdAt   DateTime  @default(now())

  @@unique([employeeId, date])
}

model Location {
  id      Int    @id @default(autoincrement())
  name    String
  address String?
  lat     Float
  lng     Float
  radius  Int    @default(100)
}

model CorrectionRequest {
  id         Int       @id @default(autoincrement())
  employeeId Int
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime  @db.Date
  type       String    // "In" or "Out"
  time       String
  reason     String
  status     ReqStatus @default(PENDING)
  reviewNote String?
  createdAt  DateTime  @default(now())
}

model Settings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Notification {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title      String
  message    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model LeaveRequest {
  id         Int       @id @default(autoincrement())
  employeeId Int
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startDate  DateTime  @db.Date
  endDate    DateTime  @db.Date
  type       String    // "Cuti", "Sakit", "Izin"
  reason     String
  status     ReqStatus @default(PENDING)
  reviewNote String?
  medicalAttachment String? // Base64 compressed image of doctor's note
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  type      String   @default("General") // "General", "Urgent", "Holiday"
  author    String   @default("HR Admin")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model MassLeave {
  id        Int      @id @default(autoincrement())
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  type      String   // "Holiday", "Cuti"
  reason    String
  createdAt DateTime @default(now())
}

model Device {
  id          Int       @id @default(autoincrement())
  name        String    // Contoh: "Mesin Lobby"
  ipAddress   String    
  port        Int       @default(4370)
  locationId  Int?      
  status      String    @default("OFFLINE")
  lastSync    DateTime? 
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  username    String
  role        String
  action      String   // "CREATE", "UPDATE", "DELETE", "IMPORT", "EXPORT", "SYNC", "LOGIN", "CORRECTION"
  entity      String   // "Employee", "Attendance", "User", "Leave", "Settings", etc.
  entityId    Int?     // ID of affected record (nullable for bulk operations)
  details     String?  // JSON or text describing what changed
  ipAddress   String?
  createdAt   DateTime @default(now())
}

// ─── Payroll System ─────────────────────────────────

model PayrollConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model SalaryComponent {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  type         String   // "ALLOWANCE" | "DEDUCTION"
  isFixed      Boolean  @default(true)   // true = nominal, false = % of base
  defaultValue Float    @default(0)
  calculationType String @default("FIXED_MONTHLY") // "FIXED_MONTHLY" | "PER_ATTENDANCE" | "CONDITIONAL"
  isTaxable    Boolean  @default(false)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  positionAllowances PositionAllowance[]
}

model PositionAllowance {
  id                Int             @id @default(autoincrement())
  position          String          // E.g., "Manager", "Staff", "Supervisor"
  salaryComponentId Int
  salaryComponent   SalaryComponent @relation(fields: [salaryComponentId], references: [id], onDelete: Cascade)
  nominal           Float           @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([position, salaryComponentId])
}

model OvertimeRule {
  id         Int      @id @default(autoincrement())
  name       String
  dayType    String   // "WORKDAY" | "WEEKEND" | "HOLIDAY"
  hourFrom   Float    // e.g. 0 = from hour 0
  hourTo     Float    // e.g. 1 = up to hour 1
  multiplier Float    // 1.5, 2.0, 3.0, 4.0
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model EmployeeSalary {
  id                   Int       @id @default(autoincrement())
  employeeId           Int       @unique
  employee             Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employmentType       String    @default("TETAP")    // TETAP, KONTRAK, HARIAN
  salaryType           String    @default("MONTHLY")  // MONTHLY, DAILY
  baseSalary           Float     @default(0)
  components           Json?     // [{componentId, name, type, value}]
  // PKWT Fields
  contractNumber       String?
  contractStart        DateTime? @db.Date
  contractEnd          DateTime? @db.Date
  contractDuration     String?
  contractRenewalCount Int       @default(0)
  // Daily Worker Fields
  dailyRate            Float?    // Tarif per hari
  minWorkingDays       Int?      // Minimum hari kerja per bulan (configurable)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Payroll {
  id              Int            @id @default(autoincrement())
  period          String         @unique // "2026-05"
  periodName      String         // "Mei 2026"
  status          PayrollStatus  @default(DRAFT)
  totalEmployees  Int            @default(0)
  totalGross      Float          @default(0)
  totalDeductions Float          @default(0)
  totalNet        Float          @default(0)
  totalOvertime   Float          @default(0)
  generatedBy     String?
  approvedBy      String?
  approvedAt      DateTime?
  rejectedBy      String?
  rejectionNote   String?
  notes           String?
  details         PayrollDetail[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model PayrollDetail {
  id               Int      @id @default(autoincrement())
  payrollId        Int
  payroll          Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employeeId       Int
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeName     String
  employeeCode     String
  department       String
  employmentType   String   // TETAP/KONTRAK/HARIAN
  salaryType       String   // MONTHLY/DAILY
  // Attendance Summary
  workingDays      Int      @default(0)
  daysPresent      Int      @default(0)
  daysAbsent       Int      @default(0)
  daysLate         Int      @default(0)
  totalLateMinutes Int      @default(0)
  // Salary Breakdown
  baseSalary       Float    @default(0)
  proRatedSalary   Float    @default(0)
  allowances       Json?    // [{name, value}]
  deductions       Json?    // [{name, value}]
  attendancePenalty Float   @default(0) // Potongan kehadiran dari keterlambatan
  overtimeHours    Float    @default(0)
  overtimePay      Float    @default(0)
  // Totals
  grossPay         Float    @default(0)
  totalDeduction   Float    @default(0)
  netPay           Float    @default(0)
  notes            String?
  createdAt        DateTime @default(now())
}
