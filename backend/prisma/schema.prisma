generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  ACCOUNTING
  DIREKTUR
  MANAGER
  EMPLOYEE
}

enum EmpStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

enum FaceStatus {
  ENROLLED
  PENDING
}

enum AttStatus {
  PRESENT
  LATE
  ABSENT
  MANGKIR
  SAKIT
  IZIN
  CUTI
  HOLIDAY
  HALF_DAY
  EARLY_DEPARTURE
}

enum ReqStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayrollStatus {
  DRAFT
  AWAITING_APPROVAL
  APPROVED
  COMPLETED
  REJECTED
  CANCELLED
}

// ─── Models ─────────────────────────────────────────

model User {
  id           Int              @id @default(autoincrement())
  username     String           @unique
  password     String
  role         Role             @default(EMPLOYEE)
  employeeId   Int?             @unique
  employee     Employee?        @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  managerAccess ManagerAccess?
  permissions  MenuPermission[]
  refreshToken String?
  mustChangePassword Boolean    @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model ManagerAccess {
  id             Int        @id @default(autoincrement())
  userId         Int        @unique
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  managedDeptId  Int?       // NULL if manageAllDepts is true
  manageAllDepts Boolean    @default(false)
}

model MenuPermission {
  id        Int     @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  menuKey   String  // e.g., "dashboard", "attendance", "employees"
  canRead   Boolean @default(true)
  canCreate Boolean @default(false)
  canUpdate Boolean @default(false)
  canDelete Boolean @default(false)

  @@unique([userId, menuKey])
}

model Employee {
  id            Int        @id @default(autoincrement())
  employeeCode  String     @unique
  name          String
  email         String     @unique
  phone         String?
  position      String?
  division      String?
  locationId    String?
  idNumber      String?
  fingerPrintId String?    // AC No. dari mesin fingerprint (ZKTeco deviceUserId)
  cardNo        String?
  verifyCode    String?
  grade             String?
  section           String?
  employmentStatus  String?
  contractDuration  String?
  joinDate          DateTime?
  contractEnd       DateTime?
  faceId            String?
  facePhoto         String?
  faceDescriptor    Json?
  bpjsTk            String?
  bpjsKesehatan     String?
  npwp              String?
  ptkpStatus        String?
  maritalStatus     String?
  kkNumber          String?
  birthDate         DateTime?
  birthPlace        String?
  address           String?
  education         String?
  major             String?
  religion          String?
  numberOfChildren  Int?
  fatherName        String?
  motherName        String?
  spouseName        String?
  emergencyContact  String?
  notes             String?
  gender            String?    // 'L' (Laki-laki) | 'P' (Perempuan)
  bankName          String?    // Nama Bank (BCA, BRI, Mandiri, dll)
  bankAccountNumber String?    // Nomor Rekening
  salaryCategory    String?    @default("UMK/UMR")
  status        EmpStatus  @default(ACTIVE)
  terminationDate   DateTime?
  terminationReason String?
  faceStatus    FaceStatus @default(PENDING)
  profilePhoto  String?
  faceEmbeddingV2 Json?     // InsightFace 512-dim vector for CCTV recognition
  faceEnrolledAt  DateTime?
  faceSamples     Int        @default(0) // Number of enrollment samples
  leaveQuota     Int        @default(12)
  remainingLeave Int        @default(12)
  departmentId  Int
  department    Department @relation(fields: [departmentId], references: [id])
  shiftId       Int?
  shift         Shift?     @relation(fields: [shiftId], references: [id])
  attendance    Attendance[]
  corrections   CorrectionRequest[]
  leaveRequests LeaveRequest[]
  shiftOverrides EmployeeShiftOverride[]
  notifications Notification[]
  fingerTemplates FingerTemplate[]
  deviceUsers    DeviceUser[]
  user          User?
  salary         EmployeeSalary?
  payrollDetails PayrollDetail[]
  documents     EmployeeDocument[]
  claims        ReimbursementClaim[]
  profileRequests ProfileUpdateRequest[]
  kpis          EmployeeKPI[]
  pushTokens    PushToken[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model EmployeeDocument {
  id              Int              @id @default(autoincrement())
  employeeId      Int
  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name            String           // e.g. "KTP", "KK", "Kontrak PKWT"
  fileUrl         String           // Path to file
  expiryDate      DateTime?        // For documents like PKWT contracts
  physicalLocator String?          // Location in physical files (e.g., "Rak A, Baris 2, Map 15")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([employeeId])
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  employees Employee[]
}

model Shift {
  id              Int                     @id @default(autoincrement())
  name            String
  startTime       String                  // "08:00"
  endTime         String                  // "17:00"
  breakStart      String?                 // "12:00"
  breakEnd        String?                 // "13:00"
  gracePeriod     Int                     @default(15)
  saturdayType    String                  @default("HALF_DAY") // "FULL_DAY", "HALF_DAY", "OFF"
  saturdayEndTime String?                 @default("13:00") // e.g. "13:00"
  employees       Employee[]
  shiftOverrides  EmployeeShiftOverride[]
}

model EmployeeShiftOverride {
  id         Int       @id @default(autoincrement())
  employeeId Int
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftId    Int
  shift      Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  startDate  DateTime  @db.Date
  endDate    DateTime  @db.Date
  createdAt  DateTime  @default(now())

  @@index([employeeId, startDate, endDate])
}

model Attendance {
  id          Int       @id @default(autoincrement())
  employeeId  Int
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime  @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  status      AttStatus @default(ABSENT)
  lateMinutes Int       @default(0)
  overtimeHours Float   @default(0)
  mode        String    @default("Credentials")
  photoUrl    String?
  checkinPhotoUrl   String?  // CCTV snapshot at check-in
  checkoutPhotoUrl  String?  // CCTV snapshot at check-out
  checkinSimilarity Float?   // Face match confidence (0.0-1.0)
  checkoutSimilarity Float?
  checkinCameraId   String?  // Camera ID that captured check-in
  checkoutCameraId  String?
  source            String   @default("manual") // face_cctv | fingerprint | face_web | manual
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  @@unique([employeeId, date])
  @@index([date])
  @@index([status])
  @@index([date, status])
}

model Location {
  id      Int    @id @default(autoincrement())
  name    String
  address String?
  lat     Float
  lng     Float
  radius  Int    @default(100)
}

model CorrectionRequest {
  id         Int       @id @default(autoincrement())
  employeeId Int
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime  @db.Date
  type       String    // "In" or "Out"
  time       String
  reason     String
  status     ReqStatus @default(PENDING)
  reviewNote String?
  createdAt  DateTime  @default(now())
}

model Settings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Notification {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title      String
  message    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model LeaveRequest {
  id         Int       @id @default(autoincrement())
  employeeId Int
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startDate  DateTime  @db.Date
  endDate    DateTime  @db.Date
  type       String    // "Cuti", "Sakit", "Izin"
  reason     String
  status     ReqStatus @default(PENDING)
  reviewNote String?
  medicalAttachment String? // Base64 compressed image of doctor's note
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  type      String   @default("General") // "General", "Urgent", "Holiday"
  author    String   @default("HR Admin")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model MassLeave {
  id        Int      @id @default(autoincrement())
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  type      String   // "Holiday", "Cuti"
  reason    String
  createdAt DateTime @default(now())
}

model Device {
  id          Int       @id @default(autoincrement())
  name        String    // Contoh: "Mesin Lobby"
  ipAddress   String    
  port        Int       @default(4370)
  locationId  Int?      
  status      String    @default("OFFLINE")
  lastSync    DateTime? 
  autoSyncEnabled Boolean @default(false)
  autoSyncTime    String?  // e.g. "17:00"
  deviceUsers    DeviceUser[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model FingerTemplate {
  id           Int      @id @default(autoincrement())
  employeeId   Int
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fingerId     Int      // 0-9 (which finger)
  templateData Bytes    // Binary fingerprint template from device
  templateSize Int      @default(0)
  quality      Int?     // Quality score if available
  enrolledAt   DateTime @default(now())
  enrolledFrom Int?     // deviceId where it was enrolled
  
  @@unique([employeeId, fingerId])
  @@index([employeeId])
}

model DeviceUser {
  id          Int      @id @default(autoincrement())
  deviceId    Int
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  employeeId  Int
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  uid         Int      // Internal UID on the device (user sn)
  acNo        String   // AC Number / Badge Number on the device
  fpCount     Int      @default(0) // Number of fingerprints on this device
  syncedAt    DateTime @default(now())
  
  @@unique([deviceId, employeeId])
  @@unique([deviceId, uid])
  @@index([deviceId])
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  username    String
  role        String
  action      String   // "CREATE", "UPDATE", "DELETE", "IMPORT", "EXPORT", "SYNC", "LOGIN", "CORRECTION"
  entity      String   // "Employee", "Attendance", "User", "Leave", "Settings", etc.
  entityId    Int?     // ID of affected record (nullable for bulk operations)
  details     String?  // JSON or text describing what changed
  ipAddress   String?
  createdAt   DateTime @default(now())
}

// ─── Payroll System ─────────────────────────────────

model PayrollConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model SalaryComponent {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  type         String   // "ALLOWANCE" | "DEDUCTION"
  isFixed      Boolean  @default(true)   // true = nominal, false = % of base
  defaultValue Float    @default(0)
  calculationType String @default("FIXED_MONTHLY") // "FIXED_MONTHLY" | "PER_ATTENDANCE" | "CONDITIONAL"
  isTaxable    Boolean  @default(false)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  positionAllowances PositionAllowance[]
}

model PositionAllowance {
  id                Int             @id @default(autoincrement())
  position          String          // E.g., "Manager", "Staff", "Supervisor"
  salaryComponentId Int
  salaryComponent   SalaryComponent @relation(fields: [salaryComponentId], references: [id], onDelete: Cascade)
  nominal           Float           @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([position, salaryComponentId])
}

model OvertimeRule {
  id         Int      @id @default(autoincrement())
  name       String
  dayType    String   // "WORKDAY" | "WEEKEND" | "HOLIDAY"
  hourFrom   Float    // e.g. 0 = from hour 0
  hourTo     Float    // e.g. 1 = up to hour 1
  multiplier Float    // 1.5, 2.0, 3.0, 4.0
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model EmployeeSalary {
  id                   Int       @id @default(autoincrement())
  employeeId           Int       @unique
  employee             Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employmentType       String    @default("TETAP")    // TETAP, KONTRAK, HARIAN
  salaryType           String    @default("MONTHLY")  // MONTHLY, DAILY
  baseSalary           Float     @default(0)
  components           Json?     // [{componentId, name, type, value}]
  // PKWT Fields
  contractNumber       String?
  contractStart        DateTime? @db.Date
  contractEnd          DateTime? @db.Date
  contractDuration     String?
  contractRenewalCount Int       @default(0)
  // Daily Worker Fields
  dailyRate            Float?    // Tarif per hari
  minWorkingDays       Int?      // Minimum hari kerja per bulan (configurable)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Payroll {
  id              Int            @id @default(autoincrement())
  period          String         @unique // "2026-05"
  periodName      String         // "Mei 2026"
  status          PayrollStatus  @default(DRAFT)
  totalEmployees  Int            @default(0)
  totalGross      Float          @default(0)
  totalDeductions Float          @default(0)
  totalNet        Float          @default(0)
  totalOvertime   Float          @default(0)
  generatedBy     String?
  approvedBy      String?
  approvedAt      DateTime?
  rejectedBy      String?
  rejectionNote   String?
  notes           String?
  details         PayrollDetail[]
  claims          ReimbursementClaim[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model PayrollDetail {
  id               Int      @id @default(autoincrement())
  payrollId        Int
  payroll          Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employeeId       Int
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeName     String
  employeeCode     String
  department       String
  employmentType   String   // TETAP/KONTRAK/HARIAN
  salaryType       String   // MONTHLY/DAILY
  // Attendance Summary
  workingDays      Int      @default(0)
  daysPresent      Int      @default(0)
  daysAbsent       Int      @default(0)
  daysLate         Int      @default(0)
  totalLateMinutes Int      @default(0)
  // Salary Breakdown
  baseSalary       Float    @default(0)
  proRatedSalary   Float    @default(0)
  allowances       Json?    // [{name, value}]
  deductions       Json?    // [{name, value}]
  attendancePenalty Float   @default(0) // Potongan kehadiran dari keterlambatan
  overtimeHours    Float    @default(0)
  overtimePay      Float    @default(0)
  // Totals
  grossPay         Float    @default(0)
  totalDeduction   Float    @default(0)
  netPay           Float    @default(0)
  notes            String?
  createdAt        DateTime @default(now())
}

model CompanyCalendar {
  id          Int      @id @default(autoincrement())
  date        DateTime @db.Date @unique
  type        String   // "HOLIDAY" or "WORKDAY"
  description String
  createdAt   DateTime @default(now())
}

// ─── Face Recognition CCTV Integration ──────────────────────────────────

model Camera {
  id          String       @id // e.g. "CAM_LOBBY_01"
  name        String
  location    String?
  ipAddress   String?
  rtspUrl     String?
  direction   String       @default("BOTH") // IN | OUT | BOTH
  active      Boolean      @default(true)
  detectUnknown Boolean    @default(true)
  captureInStart  String?  @default("06:00")
  captureInEnd    String?  @default("10:00")
  captureOutStart String?  @default("15:00")
  captureOutEnd   String?  @default("21:00")
  lastSeen    DateTime?
  faceEvents  FaceEvent[]
  unknownAlerts UnknownFaceAlert[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model FaceEvent {
  id             Int       @id @default(autoincrement())
  cameraId       String
  camera         Camera    @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  employeeId     Int?      // NULL if unknown face
  eventTime      DateTime
  similarity     Float?
  livenessScore  Float?
  isUnknown      Boolean   @default(false)
  isSpoof        Boolean   @default(false)
  photoUrl       String?
  processed      Boolean   @default(false)
  createdAt      DateTime  @default(now())

  @@index([eventTime])
  @@index([employeeId])
  @@index([isUnknown])
}

model UnknownFaceAlert {
  id          Int       @id @default(autoincrement())
  cameraId    String
  camera      Camera    @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  eventTime   DateTime
  photoUrl    String?
  similarity  Float?
  resolved    Boolean   @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
}

// ─── Chatbot Feedback Loop & NLP Configuration ──────────────────────────

model ChatLog {
  id              Int       @id @default(autoincrement())
  username        String
  userRole        String
  query           String    @db.Text
  detectedIntent  String?
  confidenceScore Float?
  response        String?   @db.Text
  feedback        String?   // 'positive', 'negative', null
  feedbackNote    String?
  responseTimeMs  Int?
  mode            String    @default("local")
  createdAt       DateTime  @default(now())

  @@index([username])
  @@index([detectedIntent])
  @@index([createdAt])
}

model NlpKeywordConfig {
  id        Int      @id @default(autoincrement())
  intent    String
  keyword   String
  weight    Float    @default(1.0)
  isActive  Boolean  @default(true)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([intent, keyword])
  @@index([intent])
}

enum ClaimCategory {
  MEDICAL
  TRAVEL
  MEAL
  OPERATIONAL
  OTHER
}

model ReimbursementClaim {
  id           Int           @id @default(autoincrement())
  employeeId   Int
  employee     Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title        String
  category     ClaimCategory
  amount       Float
  receiptUrl   String
  status       ReqStatus     @default(PENDING)
  reviewNote   String?
  payrollId    Int?
  payroll      Payroll?      @relation(fields: [payrollId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([employeeId])
  @@index([payrollId])
  @@index([status])
}

model ProfileUpdateRequest {
  id          Int       @id @default(autoincrement())
  employeeId  Int
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fieldName   String
  oldValue    String?
  newValue    String
  documentUrl String?
  status      ReqStatus @default(PENDING)
  reviewNote  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([employeeId])
  @@index([status])
}

model EmployeeKPI {
  id            Int       @id @default(autoincrement())
  employeeId    Int
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  period        String    // e.g. "2026-Q1"
  targetKPI     Json      // [{kpiName, weight, target, actual, score}]
  finalScore    Float?
  reviewNote    String?
  evaluatedBy   String
  status        ReqStatus @default(PENDING)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([employeeId, period])
  @@index([employeeId])
  @@index([status])
  @@index([period])
}

model PushToken {
  id          Int      @id @default(autoincrement())
  employeeId  Int
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  token       String   @db.Text
  platform    String   // "web" | "android" | "ios"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([employeeId])
}
