**Model baru:**

```prisma
// ─── Payroll Configuration ────────────────────────
// Master konfigurasi payroll global

model PayrollConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique   // e.g. "overtimeEnabled", "dailyWorkerRate", "pkwtAlertDays"
  value       String              // JSON string for complex values
  description String?
  updatedAt   DateTime @updatedAt
}

// ─── Salary Components ────────────────────────────
// Komponen gaji yang bisa di-customize (tunjangan, potongan)

model SalaryComponent {
  id          Int      @id @default(autoincrement())
  name        String   @unique  // "Gaji Pokok", "Tunj. Transport", "BPJS TK"
  type        String   // "ALLOWANCE" | "DEDUCTION"
  isFixed     Boolean  @default(true)  // true = nominal tetap, false = persentase
  defaultValue Float   @default(0)     // Nominal default atau persentase
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Overtime Rules ───────────────────────────────
// Aturan tarif lembur bertingkat

model OvertimeRule {
  id            Int      @id @default(autoincrement())
  name          String   // "Hari Kerja Jam 1", "Hari Libur Jam 1-8"
  dayType       String   // "WORKDAY" | "WEEKEND" | "HOLIDAY"
  hourFrom      Float    // Jam mulai (e.g. 1 = jam pertama)
  hourTo        Float    // Jam akhir (e.g. 1 = sampai jam ke-1)
  multiplier    Float    // 1.5, 2.0, 3.0, 4.0
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

// ─── Employee Salary ──────────────────────────────
// Gaji individu per karyawan (bisa manual atau template)

model EmployeeSalary {
  id              Int       @id @default(autoincrement())
  employeeId      Int       @unique
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employmentType  String    @default("TETAP")    // TETAP, KONTRAK, HARIAN
  salaryType      String    @default("MONTHLY")  // MONTHLY, DAILY
  baseSalary      Float     @default(0)           // Gaji pokok bulanan/harian
  components      Json?     // JSON array: [{componentId, name, type, value}]
  // PKWT Fields
  contractNumber  String?   // Nomor kontrak PKWT
  contractStart   DateTime? @db.Date
  contractEnd     DateTime? @db.Date
  contractDuration String?  // "6 Bulan", "1 Tahun"
  contractRenewalCount Int  @default(0)  // Jumlah perpanjangan
  // Daily Worker Fields
  dailyRate       Float?    // Tarif per hari untuk karyawan harian
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── Payroll (Monthly Run) ────────────────────────
// Record proses payroll bulanan

model Payroll {
  id            Int            @id @default(autoincrement())
  period        String         // "2026-05" (YYYY-MM)
  periodName    String         // "Mei 2026"
  status        PayrollStatus  @default(DRAFT)
  totalEmployees Int           @default(0)
  totalGross    Float          @default(0)
  totalDeductions Float        @default(0)
  totalNet      Float          @default(0)
  totalOvertime Float          @default(0)
  generatedBy   String?        // Username yang generate
  notes         String?
  details       PayrollDetail[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([period])
}

// ─── Payroll Detail (Per Employee) ────────────────
// Detail gaji per karyawan per bulan

model PayrollDetail {
  id              Int      @id @default(autoincrement())
  payrollId       Int
  payroll         Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employeeId      Int
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeName    String   // Snapshot nama saat generate
  employeeCode    String   // Snapshot NIK
  department      String   // Snapshot dept
  employmentType  String   // TETAP/KONTRAK/HARIAN
  salaryType      String   // MONTHLY/DAILY
  // Attendance Summary
  workingDays     Int      @default(0)   // Hari kerja di bulan ini
  daysPresent     Int      @default(0)   // Hari hadir
  daysAbsent      Int      @default(0)   // Hari tidak hadir
  daysLate        Int      @default(0)   // Hari terlambat
  totalLateMinutes Int     @default(0)   // Total menit terlambat
  // Salary Breakdown
  baseSalary      Float    @default(0)
  proRatedSalary  Float    @default(0)   // Gaji setelah pro-rata (harian/mangkir)
  allowances      Json?    // [{name, value}]
  deductions      Json?    // [{name, value}]
  overtimeHours   Float    @default(0)
  overtimePay     Float    @default(0)
  // Totals
  grossPay        Float    @default(0)
  totalDeduction  Float    @default(0)
  netPay          Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
}
```

**Relasi baru di Employee model:**
